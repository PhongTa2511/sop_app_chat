## Chat (Message API)
# Local backend (DTPMessageAPI)
VITE_MESSAGE_API_BASE_URL=http://localhost:3009/
VITE_MESSAGE_SOCKET_URL=http://localhost:3009/
VITE_MESSAGE_SOCKET_PATH=/socket.io

# Feature flags
# Set "1" to enable rich payload (mentions/forward metadata stored as JSON in TextContent)
VITE_MESSAGE_RICH=1
# Set "1" to enable reactions (requires backend endpoints)
VITE_MESSAGE_REACTIONS=1
